
#include <iostream>
using namespace std;
int main() {
   int size;
   cout<<"Enter the size of Array ";
   cin>>size;
   int arr[size];
   for(int i=0;i<size;i++)
   {
       cin>>arr[i];
   }
   cout<<endl;
  int min=0;
  int index=0;
   for(int i=0;i<size;i++)
   {   
       min=arr[i]; index=i;
       for(int j=i+1;j<size;j++)
       {
           if(min>arr[j])
           {
              min=arr[j];
              index=j;
           }
           arr[index]=arr[i];
           arr[i]=min;
           
       }
   }
   for(int i=0;i<size;i++)
   {
       cout<<arr[i]<<" ";
   }

    return 0;
}
