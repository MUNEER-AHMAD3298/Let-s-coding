
#include <iostream>
using namespace std;
int main() {
   int number=0,evensum=0,oddsum=0,evencount=0,oddcount=0;
   cout<<"Enter the number ";
   cin>>number;
   while(number!=0)
   {
       if(number%2==0)
       {
           evensum+=number;
           evencount++;
       }
       else
       {
           oddsum+=number;
           oddcount++;
       }
        cout<<"Enter the number ";
   cin>>number;
   }
   cout<<"Even sum = "<<evensum<<endl;
   cout<<"Odd sum = "<<oddsum<<endl;
   cout<<" Even count = "<<evencount<<endl;
   cout<<" Odd count = "<<oddcount<<endl;

    return 0;
}
