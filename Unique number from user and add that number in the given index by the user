#include <iostream>
using  namespace std;
int main() {
   int  size,unique_num;
     int index;
     bool check=false;
   cout<<"Please Enter the size of Array "<<endl;
   cin>>size;
   int arr[size];
    cout<<"Please Enter an Array of Size "<<size<<endl;
   for(int i=0;i<size;i++)
   {
       cin>>arr[i];
    
   }
   do{
       check=false;
   cout<<"Enter a unique number to add in the Array ";
   cin>>unique_num;
   for(int i=0;i<size;i++)
   {
       if(unique_num==arr[i])
       {
         check=true;
       }
   }
   }while(check==true);
   do{
 cout<<"Enter the index less than "<<size<<" in given Array at which you want to add "<<unique_num<<" "<<endl;
    cin>>index;
   }while(index>=size);
   swap(arr[index],unique_num);
  for(int i=0;i<size;i++)
   {
       cout<<arr[i]<<" ";
   }
   return 0;
}
