#include <iostream>
using namespace std;
int main() {
    // first 2D array
    int row1, col1;
    cout<<"Enter the Number of rows of First  2D Array "<<endl;
    cin>>row1;
     cout<<"Enter the Number of columns First 2D Array "<<endl;
     cin>>col1;
     cout<<"Enter the elements  in 2D Array "<<endl;
  int arr1[row1][col1];
  for(int i=0;i<row1;i++)
  {
      for(int j=0;j<col1;j++)
      {
          cin>>arr1[i][j];
      }
  }
  // second 2D array
   int row2, col2;
   cout<<"Enter the Number of rows of Second  2D Array "<<endl;
    cin>>row2;
     cout<<"Enter the Number of columns Second 2D Array "<<endl;
     cin>>col2;
     cout<<"Enter the elements  in 2D Array "<<endl;
  int arr2[row2][col2];
  for(int i=0;i<row2;i++)
  {
      for(int j=0;j<col2;j++)
      {
          cin>>arr2[i][j];
      }
  }
  // third 2D array to add first and second 2D array 

    int arr3[row2][col2];
    for(int i=0;i<row2;i++)
  {
      for(int j=0;j<col2;j++)
      {
          arr3[i][j]=arr1[i][j]+arr2[i][j];
      }
  }
  // to show the output of third 2d Array
  for(int i=0;i<row2;i++)
  {
      for(int j=0;j<col2;j++)
      {
          cout<<arr3[i][j]<<" ";
      }
      cout<<endl;
  }
    
    return 0;
}
